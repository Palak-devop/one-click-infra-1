global:
  scrape_interval: 10s
  external_labels:
    datacenter: ap-south-1

scrape_configs:
  - job_name: 'vmagent'
    static_configs:
      - targets: ['localhost:8429']

  - job_name: 'nginx-exporter'
    static_configs:
      - targets: ['localhost:9113']

  - job_name: 'node-exporter'
    static_configs:
      - targets:
        {% for host in groups['private_hosts'] %}
        - '{{ hostvars[host]["ansible_host"] }}:9100'
        {% endfor %}
