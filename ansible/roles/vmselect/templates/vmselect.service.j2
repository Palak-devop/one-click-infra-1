[Unit]
Description=VictoriaMetrics Cluster Query Node (vmselect)
Wants=network-online.target
After=network-online.target

[Service]
User=victoria-metrics
Group=victoria-metrics
Type=simple
ExecStart=/usr/local/bin/vmselect \
  -httpListenAddr=:8481 \
  -storageNode={% for host in groups['vm_storage'] %}{{ hostvars[host]['ansible_host'] }}:8401{% if not loop.last %},{% endif %}{% endfor %}
Restart=always
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
