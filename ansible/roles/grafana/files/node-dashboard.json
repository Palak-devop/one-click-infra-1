      },
      "id": 1,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "default"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "default"
          },
          "editorMode": "code",
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}} - CPU Usage",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "default"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "default"
          },
          "editorMode": "code",
          "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
          "legendFormat": "{{instance}} - Memory Used (%)",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Disk Space Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "default"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "default"
          },
          "editorMode": "code",
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)",
          "legendFormat": "{{instance}} - / Disk Space Used (%)",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Network Traffic (Receive)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "default"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "default"
          },
          "editorMode": "code",
          "expr": "sum by (instance) (irate(node_network_receive_bytes_total{device!~\"lo\"}[5m]))",
          "legendFormat": "{{instance}} - RX Bytes/sec",
          "range": true,
          "refId": "A"
        }
      ]
    }
