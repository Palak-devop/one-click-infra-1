[Unit]
Description=VictoriaMetrics Cluster Storage Node (vmstorage)
Wants=network-online.target
After=network-online.target

[Service]
User=victoria-metrics
Group=victoria-metrics
Type=simple
ExecStart=/usr/local/bin/vmstorage \
  -storageDataPath=/data/vmstorage/db \
  -retentionPeriod=1 \
  -httpListenAddr=:8482 \
  -vminsertAddr=:8400 \
  -vmselectAddr=:8401
Restart=always
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
